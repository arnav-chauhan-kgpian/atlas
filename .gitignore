# =============================================================================
# Atlas — .gitignore
# =============================================================================

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ── Virtual environments ───────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── IDE / Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── Testing ────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Training artifacts ─────────────────────────────────────────────────────
runs/
*.pt
*.ckpt
wandb/

# ── Logging ────────────────────────────────────────────────────────────────
*.tfevents*
logs/

# ── OS files ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Misc ───────────────────────────────────────────────────────────────────
*.log
finetune_config.yaml
